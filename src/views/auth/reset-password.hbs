<!DOCTYPE html>
<html>
<head>
  <title>{{title}}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f6f7f9;
      padding: 40px 12px;
    }

    .card {
      max-width: 520px;
      margin: auto;
      padding: 24px;
      background: #fff;
      border-radius: 12px;
      border: 1px solid #eee;
      text-align: center;
    }

    .logo img {
      height: 50px;
      margin-bottom: 20px;
    }

    h2 {
      color: #333;
      margin-bottom: 10px;
    }

    p {
      color: #444;
      font-size: 15px;
      margin-bottom: 20px;
    }

    input {
      width: 100%;
      padding: 12px;
      margin-top: 12px;
      font-size: 14px;
      border: 1px solid #ccc;
      border-radius: 6px;
      box-sizing: border-box;
    }

    button {
      margin-top: 18px;
      padding: 12px;
      width: 100%;
      background: #4CAF50;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-size: 15px;
      cursor: pointer;
    }

    button:hover {
      background: #43a047;
    }

    hr {
      margin: 26px 0;
      border: 0;
      border-top: 1px solid #eee;
    }

    .footer {
      color: #888;
      font-size: 12px;
    }
  </style>
</head>
<body>

  <div class="card">

    {{#if logo}}
      <div class="logo">
        <img src="{{logo}}" alt="Logo">
      </div>
    {{/if}}

    <h2>Reset Password</h2>
    <p>Please enter your new password below.</p>

    <form method="POST" action="/api/users/auth/reset-password">
      <input type="hidden" name="token" value="{{token}}" />

      <input
        type="password"
        name="new_password"
        placeholder="New password"
        required
      />

      <input
        type="password"
        name="confirm_password"
        placeholder="Confirm new password"
        required
      />

      <button type="submit">Reset Password</button>
    </form>

    <hr>

    <div class="footer">
      © {{year}} {{appName}}
    </div>

  </div>

</body>
</html>
