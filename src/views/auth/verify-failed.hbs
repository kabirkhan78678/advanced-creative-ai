<!DOCTYPE html>
<html>
<head>
  <title>{{title}}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      background: #f4f6f8;
      padding: 32px 12px;
      margin: 0;
    }

    .card {
      max-width: 520px;
      margin: auto;
      padding: 28px 24px;
      background: #ffffff;
      border-radius: 14px;
      border: 1px solid #e5e7eb;
      text-align: center;
      box-shadow: 0 6px 20px rgba(0,0,0,0.05);
    }

    .logo img {
      height: 46px;
      margin-bottom: 18px;
    }

    h2 {
      color: #92400e; /* soft amber, not red */
      margin: 10px 0 14px;
      font-size: 22px;
    }

    p {
      color: #374151;
      font-size: 15px;
      line-height: 1.6;
      margin-bottom: 16px;
    }

    .info {
      font-size: 14px;
      color: #4b5563;
      margin-top: 10px;
    }

    hr {
      margin: 26px 0 16px;
      border: 0;
      border-top: 1px solid #e5e7eb;
    }

    .footer {
      color: #6b7280;
      font-size: 12px;
    }
  </style>
</head>
<body>

  <div class="card">

    {{#if logo}}
      <div class="logo">
        <img src="{{logo}}" alt="{{appName}} Logo">
      </div>
    {{/if}}

    <h2>Verification Unavailable</h2>

    <p>
      {{message}}
    </p>

    <div class="info">
      This may happen if the link has expired or was already used.
      You can request a new verification email if needed.
    </div>

    <hr>

    <div class="footer">
      © {{year}} {{appName}}. All rights reserved.
    </div>

  </div>

</body>
</html>
